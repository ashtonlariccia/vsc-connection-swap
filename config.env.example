# connection-swap configuration
# Copy this file to config.env and fill in your values.

# WSL
WSL_DISTRO=your-wsl-distro-name
WSL_USER=your-wsl-username

# SSH remote
SSH_HOST=your-ssh-hostname
SSH_USER=your-ssh-username

# Local paths (used for future features)
LOCAL_PATH=C:\Users\yourname\path\to\workspace
LOCAL_PATH_WSL=/mnt/c/Users/yourname/path/to/workspace
